{
  "name": "piston-listener-cloudflare",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "d1:create": "wrangler d1 create piston-listener-catalog",
    "d1:migrate:local": "wrangler d1 migrations apply piston-listener-catalog --local",
    "d1:migrate": "wrangler d1 migrations apply piston-listener-catalog --remote",
    "r2:create": "wrangler r2 bucket create piston-listener-samples",
    "secret:upload-token": "wrangler secret put UPLOAD_TOKEN"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "typescript": "latest",
    "wrangler": "latest"
  }
}
